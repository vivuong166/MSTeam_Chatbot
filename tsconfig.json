{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",

    "lib": ["ES2020"],
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,

    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "scripts"]
}